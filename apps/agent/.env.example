# OpenMeet AI Agent - Environment Configuration

# === Provider Selection ===
# STT: local | openai | groq
STT_PROVIDER=openai

# LLM: local | openai | groq
LLM_PROVIDER=openai

# === Local STT (Whisper) — chỉ cần khi STT_PROVIDER=local ===
WHISPER_MODEL=base
WHISPER_DEVICE=cpu

# === OpenAI-compatible STT — chỉ cần khi STT_PROVIDER=openai ===
OPENAI_STT_API_KEY=your-api-key-here
OPENAI_STT_BASE_URL=https://api.openai.com/v1
OPENAI_STT_MODEL=whisper-1

# === Local LLM (Ollama) — chỉ cần khi LLM_PROVIDER=local ===
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# === OpenAI-compatible LLM — chỉ cần khi LLM_PROVIDER=openai ===
OPENAI_LLM_API_KEY=your-api-key-here
OPENAI_LLM_BASE_URL=https://api.openai.com/v1
OPENAI_LLM_MODEL=gpt-4o-mini

# === Groq (nếu Provider=groq) ===
# GROQ_API_KEY=your-groq-key
# GROQ_STT_MODEL=whisper-large-v3
# GROQ_LLM_MODEL=llama-3.3-70b-versatile

# === LiveKit (cho real-time audio track integration) ===
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=your-livekit-secret
