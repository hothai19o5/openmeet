# OpenMeet AI Agent - Environment Configuration

# === Provider Selection ===
# STT: local | whisperx | openai | groq
STT_PROVIDER=openai

# LLM: local | openai | groq
LLM_PROVIDER=openai

# === STT: Option A — Local Whisper (faster-whisper, CPU, no diarization) ===
WHISPER_MODEL=base
WHISPER_DEVICE=cpu

# === STT: Option C — WhisperX + pyannote 3.1 (GPU, full diarization) ===
WHISPERX_MODEL=large-v3
WHISPERX_DEVICE=cuda
WHISPERX_COMPUTE_TYPE=float16
# HuggingFace token: accept license at huggingface.co/pyannote/speaker-diarization-3.1
HF_TOKEN=
WHISPERX_MIN_SPEAKERS=0
WHISPERX_MAX_SPEAKERS=0

# === STT: Option B — OpenAI-compatible API ===
OPENAI_STT_API_KEY=your-api-key-here
OPENAI_STT_BASE_URL=https://api.openai.com/v1
OPENAI_STT_MODEL=whisper-1

# === STT: Option B variant — Groq API (free tier, fast) ===
# GROQ_API_KEY=your-groq-api-key
# GROQ_STT_MODEL=whisper-large-v3

# === LLM: Local Ollama ===
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# === LLM: OpenAI-compatible API ===
OPENAI_LLM_API_KEY=your-api-key-here
OPENAI_LLM_BASE_URL=https://api.openai.com/v1
OPENAI_LLM_MODEL=gpt-4o-mini

# === LLM: Groq (nếu LLM_PROVIDER=groq) ===
# GROQ_LLM_MODEL=llama-3.3-70b-versatile

# === LiveKit (cho real-time audio track integration) ===
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
